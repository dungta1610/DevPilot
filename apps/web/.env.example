# DevPilot frontend environment

# Base URL of the NestJS backend
NEXT_PUBLIC_API_URL=http://localhost:3001

# When "true", the UI reads from lib/mocks.ts instead of hitting the backend.
# This lets the entire UI (including the simulated agent stream) run with no backend.
NEXT_PUBLIC_USE_MOCKS=true

# --- NextAuth (only needed when NEXT_PUBLIC_USE_MOCKS != "true") ---
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
