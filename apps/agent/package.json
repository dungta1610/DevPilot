{
  "name": "agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DevPilot durable PR-review agent (Restate + LangGraph + Gemini)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "register": "curl -X POST http://localhost:9070/deployments -H 'Content-Type: application/json' -d '{\"uri\": \"http://host.docker.internal:9080\"}'"
  },
  "dependencies": {
    "@langchain/core": "^1.1.49",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.4.2",
    "@octokit/rest": "^22.0.1",
    "@restatedev/restate-sdk": "^1.14.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
