# Restate ingress (used by tooling / clients)
RESTATE_SERVER_URL=http://localhost:8080

# Port this agent's Restate SDK HTTP server listens on
AGENT_PORT=9080

# Gemini — required when an LLM node runs
GOOGLE_API_KEY=your-gemini-api-key

# GitHub token used to read PRs and post review comments
GITHUB_APP_TOKEN=your-github-token

# NestJS internal API — where step progress is reported (powers the SSE stream)
API_INTERNAL_URL=http://localhost:3001
# Must match apps/api's API_INTERNAL_SECRET
API_INTERNAL_SECRET=dev-internal-secret
