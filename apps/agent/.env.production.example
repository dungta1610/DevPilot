# apps/agent — production env (set these in the Railway dashboard, not in the repo)

NODE_ENV=production

# Railway exposes ONE public port per service via $PORT, and Restate Cloud calls
# the agent on that public URL — so the Restate SDK server must listen on it.
AGENT_PORT=${PORT}
# The :9081 liveness probe is not publicly routable on Railway (single port);
# it's there for orchestrators that allow a second port. Safe to leave default.
AGENT_HEALTH_PORT=9081

# LLM + GitHub
GOOGLE_API_KEY=                 # Gemini API key
GITHUB_APP_TOKEN=               # GitHub PAT with repo scope (read PRs, post comments)

# Restate Cloud (the agent is registered with Cloud; these are for parity/tools)
RESTATE_SERVER_URL=https://<env-id>.ingress.<region>.restate.cloud
RESTATE_API_KEY=                # Restate Cloud API key

# Internal API callbacks → the NestJS service
API_INTERNAL_URL=https://your-api.up.railway.app
API_INTERNAL_SECRET=            # MUST match the api service's value

# Optional: shorten the digest loop for demos (default 24h)
# DIGEST_INTERVAL_MS=60000
