# apps/api — production env (set these in the Railway dashboard, not in the repo)

NODE_ENV=production
PORT=3001                       # Railway injects $PORT; the app reads it automatically

# Railway PostgreSQL plugin provides this automatically
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Auth
JWT_SECRET=                     # strong random string
JWT_EXPIRES_IN=7d
GITHUB_CLIENT_ID=               # from the GitHub OAuth app
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-api.up.railway.app/auth/github/callback
FRONTEND_URL=https://your-app.vercel.app

# Restate Cloud
RESTATE_INGRESS_URL=https://<env-id>.ingress.<region>.restate.cloud
RESTATE_API_KEY=                # Restate Cloud API key (bearer token)

# Shared secret the agent presents on /internal/* callbacks — MUST match the agent
API_INTERNAL_SECRET=            # strong random string
