# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/devpilot"

# App
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# Restate ingress (where review workflows are submitted / awakeables resolved)
RESTATE_INGRESS_URL=http://localhost:8080

# Shared secret the agent service presents on internal progress callbacks.
# Must match apps/agent's API_INTERNAL_SECRET.
API_INTERNAL_SECRET=dev-internal-secret
